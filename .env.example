# Скопируй этот файл в .env и заполни значения
# cp .env.example .env

# Пароль для PostgreSQL библиотеки (придумай сложный)
DB_PASSWORD=change_me_strong_password_here

# API-ключ для защиты эндпоинтов загрузки файлов (придумай сложный)
API_KEY=change_me_api_key_here

# Пароль для входа в админку (вводится на странице логина)
ADMIN_PASSWORD=change_me_admin_password_here
